NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPER_ADMIN_EMAIL=admin@example.com

# ─── Caisse session (required in production) ─────────────────────────────────
# Random 32+ byte string used to sign HMAC-SHA256 caisse session tokens.
# Rotate this value to immediately invalidate all active caisse sessions.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CAISSE_SESSION_SECRET=change-me-to-a-random-32-byte-hex-string

# ─── Distributed rate limiting (optional) ────────────────────────────────────
# Set USE_DISTRIBUTED_RATE_LIMIT=true and provide Upstash credentials to
# enable multi-instance / serverless-safe rate limiting backed by Upstash Redis.
# When this variable is absent or false the in-memory fallback is used (fine for
# single-instance and local development).
USE_DISTRIBUTED_RATE_LIMIT=false
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token
